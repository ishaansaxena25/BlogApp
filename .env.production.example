# ============================================================
# BlogBubble — Production Environment (VPS / Self-Hosted)
# ============================================================
# This is an EXAMPLE file for deploying BlogBubble on a VPS
# (e.g., DigitalOcean, Linode, Hetzner) using docker-compose
# with self-hosted MongoDB and Redis containers.
#
# ⚠️  SETUP INSTRUCTIONS:
#   1. Copy this file:  cp .env.production.example .env.production
#   2. Replace ALL "CHANGE_THIS_*" values with real secrets.
#   3. Never commit .env.production to version control.
#
# 🔒 Generate strong secrets with:
#      node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   or openssl rand -hex 64
# ============================================================

# -----------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------

# Port the Express backend listens on inside the container.
# Nginx reverse-proxies external traffic to this port.
PORT=3000

# Set to "production" for optimised performance, minimal logging,
# and secure defaults (e.g., secure cookies, no stack traces).
NODE_ENV=production

# -----------------------------------------------------------
# MongoDB Configuration (Authenticated)
# -----------------------------------------------------------

# Connection string with authentication.
# - "blogbubble_admin" is the MongoDB user created on first run.
# - "authSource=admin" tells Mongo to authenticate against the
#   admin database where the root user is stored.
# - The hostname "mongodb" is the Docker Compose service name.
#
# ⚠️  Replace CHANGE_THIS_PASSWORD with a strong password.
MONGODB_URI=mongodb://blogbubble_admin:CHANGE_THIS_PASSWORD@mongodb:27017/blogbubble?authSource=admin

# These variables are read by the official mongo Docker image on
# FIRST RUN ONLY to create the root/admin user.
# They must match the credentials in MONGODB_URI above.
MONGO_INITDB_ROOT_USERNAME=blogbubble_admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_THIS_PASSWORD

# -----------------------------------------------------------
# JWT (JSON Web Token) Authentication
# -----------------------------------------------------------

# Secret key used to sign and verify JWTs.
# ⚠️  MUST be changed to a long, random string.
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# Token expiration duration.
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------
# Image Storage Configuration
# -----------------------------------------------------------

MAX_FILE_SIZE=5242880

# Production requires all R2 values unless local storage is explicitly
# selected with STORAGE_DRIVER=local and backed by a persistent volume.
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=CHANGE_THIS_ACCESS_KEY
R2_SECRET_ACCESS_KEY=CHANGE_THIS_SECRET_KEY
R2_BUCKET=blogbubble-storage
R2_PUBLIC_URL=https://images.yourdomain.com

# -----------------------------------------------------------
# Redis Configuration (Password-Protected)
# -----------------------------------------------------------

# Redis connection URL with password authentication.
# The format is: redis://:PASSWORD@hostname:port
# ⚠️  Replace CHANGE_THIS_PASSWORD with a strong password.
REDIS_URL=redis://:CHANGE_THIS_PASSWORD@redis:6379

# Password passed to the Redis container via docker-compose
# (used by the redis service's --requirepass flag).
# Must match the password in REDIS_URL above.
REDIS_PASSWORD=CHANGE_THIS_PASSWORD

# Cache TTL in seconds. Higher in production for better performance.
CACHE_TTL_SECONDS=120

# -----------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------

# The public URL of your frontend.
# If the frontend is hosted on a separate domain (e.g., Vercel),
# set this to that domain. If served by nginx on the same VPS,
# set this to your VPS domain.
# ⚠️  Replace with your actual domain.
CORS_ORIGIN=https://yourdomain.com
