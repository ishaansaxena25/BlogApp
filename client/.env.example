# BlogBubble Frontend Environment Configuration Template
# Copy this file to a new file named '.env' in this directory and update values as needed.

# The base URL of the backend API server (e.g. http://localhost:3000 for local development).
# When deploying the frontend and backend on the same domain in the cloud (single-domain),
# you can leave this blank or comment it out to default to relative CORS-free API calls.
VITE_API_URL=http://localhost:3000
