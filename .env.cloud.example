# ============================================================
# BlogBubble — Cloud Services Environment
# ============================================================
# This is an EXAMPLE file for deploying BlogBubble using
# managed cloud services instead of self-hosted containers:
#   - MongoDB Atlas  (managed MongoDB)
#   - Redis Cloud / Upstash / Aiven  (managed Redis)
#   - Backend on Render / Railway / Fly.io / AWS ECS
#   - Frontend on Vercel / Netlify / Cloudflare Pages
#
# ⚠️  SETUP INSTRUCTIONS:
#   1. Copy this file:  cp .env.cloud.example .env
#   2. Replace ALL placeholder values with your real credentials.
#   3. If your platform uses a dashboard for env vars (e.g.,
#      Render, Railway), paste these key=value pairs there instead.
#   4. Never commit real credentials to version control.
# ============================================================

# -----------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------

# Port the Express backend listens on.
# Many cloud platforms set PORT automatically via their own env var;
# this acts as a fallback.
PORT=3000

# Always "production" for cloud deployments.
NODE_ENV=production

# -----------------------------------------------------------
# MongoDB Atlas Configuration
# -----------------------------------------------------------

# MongoDB Atlas connection string (SRV format).
# Get this from: Atlas Dashboard → Connect → Drivers → Node.js
#
# Replace:
#   - "username"  → your Atlas database user
#   - "password"  → the user's password
#   - "cluster.mongodb.net" → your cluster hostname
#
# The "retryWrites=true&w=majority" options ensure write reliability
# across Atlas replica sets.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/blogbubble?retryWrites=true&w=majority

# -----------------------------------------------------------
# JWT (JSON Web Token) Authentication
# -----------------------------------------------------------

# Secret key used to sign and verify JWTs.
# ⚠️  MUST be changed to a long, random string.
#
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# Token expiration duration.
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------

# Directory (relative to backend root) for blog post uploads.
# Note: On ephemeral cloud platforms (Render, Railway), local
# file storage is lost on redeploy. Consider using an S3-compatible
# object store (AWS S3, Cloudflare R2) for persistent uploads.
UPLOAD_DIR=public/uploads

# Directory (relative to backend root) for profile pictures.
PROFILE_UPLOAD_DIR=public/profile

# Maximum file size in bytes (5 MB).
MAX_FILE_SIZE=5242880

# -----------------------------------------------------------
# Redis Cloud Configuration
# -----------------------------------------------------------

# Redis connection URL from your managed Redis provider.
# Providers & where to find the URL:
#   - Redis Cloud: Database → Configuration → Public endpoint
#   - Upstash:     Database → REST URL (use redis:// URL)
#   - Aiven:       Service → Connection information
#
# Format: redis://default:password@hostname:port
REDIS_URL=redis://default:password@redis-cloud-host:port

# Cache TTL in seconds.
CACHE_TTL_SECONDS=120

# -----------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------

# The public URL of your frontend deployment.
# Examples:
#   - Vercel:           https://blogbubble.vercel.app
#   - Netlify:          https://blogbubble.netlify.app
#   - Custom domain:    https://yourdomain.com
#
# ⚠️  Replace with your actual frontend URL (no trailing slash).
CORS_ORIGIN=https://yourdomain.vercel.app
